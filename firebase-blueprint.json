{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user information and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Theme": {
      "title": "City Walk Theme",
      "description": "A theme created by the community or system",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "missions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "category", "missions", "authorId", "status"]
    },
    "Walk": {
      "title": "City Walk Record",
      "description": "A record of a completed or ongoing city walk",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "themeTitle": { "type": "string" },
        "photoUrl": { "type": "string" },
        "videoUrl": { "type": "string" },
        "audioUrl": { "type": "string" },
        "noteText": { "type": "string" },
        "recordUnit": { "type": "string", "enum": ["location", "event", "image"] },
        "isPublic": { "type": "boolean" },
        "locationName": { "type": "string" },
        "path": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "lat": { "type": "number" },
              "lng": { "type": "number" },
              "timestamp": { "type": "number" }
            }
          }
        },
        "completedMissions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "mission": { "type": "string" },
              "mediaUrl": { "type": "string" },
              "mediaType": { "type": "string" }
            }
          }
        },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "themeTitle", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/themes/{themeId}": {
      "schema": "Theme",
      "description": "Community contributed themes"
    },
    "/walks/{walkId}": {
      "schema": "Walk",
      "description": "User walk history and footprints"
    }
  }
}
