rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "zouxintong82@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // Themes
    match /themes/{themeId} {
      allow read: if true; // Publicly readable
      allow create: if isAuthenticated() && 
        hasOnlyAllowedFields(['title', 'description', 'category', 'missions', 'authorId', 'authorName', 'status', 'createdAt']) &&
        request.resource.data.authorId == request.auth.uid &&
        request.resource.data.status == 'pending';
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.authorId == request.auth.uid && resource.data.status == 'pending');
    }

    // Walks
    match /walks/{walkId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.isPublic == true || isAdmin());
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid &&
        hasOnlyAllowedFields(['userId', 'themeTitle', 'photoUrl', 'videoUrl', 'audioUrl', 'noteText', 'recordUnit', 'path', 'completedMissions', 'timestamp', 'isPublic', 'locationName']);
      allow update: if isAuthenticated() && 
        resource.data.userId == request.auth.uid &&
        hasOnlyAllowedFields(['userId', 'themeTitle', 'photoUrl', 'videoUrl', 'audioUrl', 'noteText', 'recordUnit', 'path', 'completedMissions', 'timestamp', 'isPublic', 'locationName']);
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }
  }
}
